{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "godaddy/asherah",
    "description": "PHP FFI bindings for Asherah envelope encryption.",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Jay Gowdy"
        }
    ],
    "homepage": "https://github.com/godaddy/asherah-ffi",
    "keywords": [
        "asherah",
        "encryption",
        "envelope-encryption",
        "ffi",
        "kms"
    ],
    "support": {
        "issues": "https://github.com/godaddy/asherah-ffi/issues",
        "source": "https://github.com/godaddy/asherah-ffi"
    },
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.40",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "GoDaddy\\Asherah\\": "asherah-php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GoDaddy\\Asherah\\Tests\\": "asherah-php/tests/"
        }
    },
    "scripts": {
        "download-native": "php asherah-php/scripts/install_native.php",
        "verify-native": "php asherah-php/scripts/install_native.php --verify",
        "test": "vendor/bin/phpunit -c asherah-php/phpunit.xml",
        "test:smoke": "php asherah-php/tests/smoke.php",
        "phpstan": "vendor/bin/phpstan analyse --configuration=asherah-php/phpstan.neon --memory-limit=256M",
        "cs-check": "vendor/bin/php-cs-fixer fix --config=asherah-php/.php-cs-fixer.php --dry-run --diff --allow-unsupported-php-version=yes",
        "cs-fix": "vendor/bin/php-cs-fixer fix --config=asherah-php/.php-cs-fixer.php --diff --allow-unsupported-php-version=yes"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "archive": {
        "exclude": [
            "/.cargo",
            "/.claude",
            "/.dockerignore",
            "/.editorconfig",
            "/.git",
            "/.github",
            "/.gitignore",
            "/.pre-commit-config.yaml",
            "/AGENTS.md",
            "/BUILD_RULES.md",
            "/CLAUDE.md",
            "/Cargo.lock",
            "/Cargo.toml",
            "/PUBLISHING.md",
            "/RELEASING.md",
            "/asherah",
            "/asherah-cobhan",
            "/asherah-config",
            "/asherah-dotnet",
            "/asherah-ffi",
            "/asherah-go",
            "/asherah-java",
            "/asherah-node",
            "/asherah-php/.Dockerfile.alpine",
            "/asherah-php/.Dockerfile.debian",
            "/asherah-php/.gitignore",
            "/asherah-php/.php-cs-fixer.php",
            "/asherah-php/.php-cs-fixer.cache",
            "/asherah-php/.phpunit.cache",
            "/asherah-php/composer.lock",
            "/asherah-php/native",
            "/asherah-php/phpstan.neon",
            "/asherah-php/phpunit.xml",
            "/asherah-php/tests",
            "/asherah-php/vendor",
            "/asherah-py",
            "/asherah-ruby",
            "/asherah-server",
            "/benchmarks",
            "/docker",
            "/docs",
            "/e2e",
            "/fuzz",
            "/global.json",
            "/interop",
            "/interop-grpc",
            "/rust-toolchain.toml",
            "/samples",
            "/scripts",
            "/src",
            "/target",
            "/target-*",
            "/valgrind.supp"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
